@@
+from copy import deepcopy
+
+from django.db import IntegrityError, transaction
+
+from .models import (
+    BehaviouralQuestion,
+    ConceptQuestion,
+    DebugQuestion,
+    Question,
+    TechnicalQuestion,
+    UserQuestionNote,
+    UserQuestionState,
+)
+
+
+TYPE_FIELDS = {
+    TechnicalQuestion: (
+        "topic",
+        "first_hint",
+        "pattern",
+        "data_structure",
+        "intuition",
+        "brute_force",
+        "brute_force_time_complexity",
+        "brute_force_space_complexity",
+        "optimal_approach",
+        "optimal_time_complexity",
+        "optimal_space_complexity",
+        "complexity",
+        "mistakes",
+        "progressive_hints",
+        "code",
+    ),
+    ConceptQuestion: (
+        "category",
+        "canonical_answer",
+        "key_points",
+        "example",
+        "common_misconception",
+        "code_snippet",
+    ),
+    BehaviouralQuestion: (
+        "star_answer",
+        "leadership_principles",
+        "stories",
+        "follow_ups",
+        "competencies",
+        "star_outline",
+        "personal_detail_prompts",
+        "follow_up_questions",
+        "common_mistakes",
+    ),
+    DebugQuestion: (
+        "repository",
+        "bug_type",
+        "failing_test_or_symptom",
+        "broken_code",
+        "likely_bug",
+        "reasoning",
+        "fix",
+        "tests",
+        "common_mistake",
+    ),
+}
+
+
+def _copy_personal_data(*, user, source, target):
+    source_note = UserQuestionNote.objects.filter(
+        user=user,
+        question=source,
+    ).first()
+    if source_note:
+        UserQuestionNote.objects.update_or_create(
+            user=user,
+            question=target,
+            defaults={
+                "notes": source_note.notes,
+                "mistakes": source_note.mistakes,
+                "code_notes": source_note.code_notes,
+                "behavioural_notes": source_note.behavioural_notes,
+            },
+        )
+
+    source_state = UserQuestionState.objects.filter(
+        user=user,
+        question=source,
+    ).first()
+    if source_state:
+        UserQuestionState.objects.update_or_create(
+            user=user,
+            question=target,
+            defaults={
+                "status": source_state.status,
+                "bookmarked": False,
+                "started_at": source_state.started_at,
+                "ready_at": source_state.ready_at,
+            },
+        )
+
+
+def add_system_question_to_user(*, question, user):
+    if not question.is_system:
+        raise ValueError("Only built-in questions can be added to a user library.")
+
+    existing = Question.objects.filter(
+        owner=user,
+        source_system_question=question,
+    ).first()
+    if existing:
+        return existing.specific, False
+
+    specific = question.specific
+    model = type(specific)
+    field_names = TYPE_FIELDS.get(model)
+    if not field_names:
+        raise ValueError("The built-in question has no supported subtype.")
+
+    values = {
+        "owner": user,
+        "source_system_question": question,
+        "title": question.title,
+        "prompt": question.prompt,
+        "company": question.company,
+        "difficulty": question.difficulty,
+        "status": Question.Status.NEEDS_NOTES,
+    }
+    values.update(
+        {
+            field_name: deepcopy(getattr(specific, field_name))
+            for field_name in field_names
+        }
+    )
+
+    try:
+        with transaction.atomic():
+            user_question = model.objects.create(**values)
+    except IntegrityError:
+        existing = Question.objects.get(
+            owner=user,
+            source_system_question=question,
+        )
+        return existing.specific, False
+
+    _copy_personal_data(
+        user=user,
+        source=question,
+        target=user_question,
+    )
+
+    if user_question.can_mark_ready:
+        user_question.mark_ready()
+
+    return user_question, True
diff --git a/apps/questions/management/commands/convert_saved_built_ins.py b/apps/questions/management/commands/convert_saved_built_ins.py
new file mode 100644
--- /dev/null
+++ b/apps/questions/management/commands/convert_saved_built_ins.py
@@
+from django.core.management.base import BaseCommand
+
+from apps.questions.models import UserQuestionState
+from apps.questions.system_copy import add_system_question_to_user
+
+
+class Command(BaseCommand):
+    help = "Convert bookmarked built-in questions into user-owned copies."
+
+    def handle(self, *args, **options):
+        states = UserQuestionState.objects.select_related(
+            "user",
+            "question",
+        ).filter(
+            bookmarked=True,
+            question__is_system=True,
+        )
+
+        created_count = 0
+        existing_count = 0
+
+        for state in states.iterator():
+            _, created = add_system_question_to_user(
+                question=state.question,
+                user=state.user,
+            )
+            if created:
+                created_count += 1
+            else:
+                existing_count += 1
+
+            state.bookmarked = False
+            state.save(update_fields=["bookmarked", "updated_at"])
+
+        self.stdout.write(
+            self.style.SUCCESS(
+                f"Created {created_count} user copies; "
+                f"{existing_count} already existed."
+            )
+        )
