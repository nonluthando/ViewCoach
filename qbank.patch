+      "java_solution": "import java.util.ArrayDeque;\nimport java.util.ArrayList;\nimport java.util.Deque;\nimport java.util.List;\n\npublic class Main {\n    public static boolean canCompleteAll(\n            int courseCount,\n            int[][] prerequisites) {\n\n        List<List<Integer>> dependentCourses = new ArrayList<>();\n\n        for (int course = 0; course < courseCount; course++) {\n            dependentCourses.add(new ArrayList<>());\n        }\n\n        int[] indegrees = new int[courseCount];\n\n        for (int[] pair : prerequisites) {\n            int course = pair[0];\n            int prerequisite = pair[1];\n\n            dependentCourses.get(prerequisite).add(course);\n            indegrees[course]++;\n        }\n\n        Deque<Integer> availableCourses = new ArrayDeque<>();\n\n        for (int course = 0; course < courseCount; course++) {\n            if (indegrees[course] == 0) {\n                availableCourses.offer(course);\n            }\n        }\n\n        int completedCourses = 0;\n\n        while (!availableCourses.isEmpty()) {\n            int completedCourse = availableCourses.poll();\n            completedCourses++;\n\n            for (int dependentCourse : dependentCourses.get(completedCourse)) {\n                indegrees[dependentCourse]--;\n\n                if (indegrees[dependentCourse] == 0) {\n                    availableCourses.offer(dependentCourse);\n                }\n            }\n        }\n\n        return completedCourses == courseCount;\n    }\n\n    public static void main(String[] args) {\n        int[][] possible = {{1, 0}, {2, 1}, {3, 1}};\n        int[][] impossible = {{1, 0}, {0, 1}};\n\n        System.out.println(canCompleteAll(4, possible));\n        System.out.println(canCompleteAll(2, impossible));\n    }\n}"
