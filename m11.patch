+{% extends "base.html" %}
+
+{% block title %}Import Questions | Adaptive Interview Coach{% endblock %}
+
+{% block content %}
+<section class="page-header compact-header">
+    <p class="eyebrow">Bulk question import</p>
+    <h1>Turn a list into questions</h1>
+    <p class="lead">Paste or upload a question list. You will review every extracted question before anything is created.</p>
+</section>
+
+<form class="form-card form-card-wide" method="post" enctype="multipart/form-data" novalidate>
+    {% csrf_token %}
+    {% if form.non_field_errors %}<div class="form-errors">{{ form.non_field_errors }}</div>{% endif %}
+
+    {% for field in form %}
+        <div class="form-field">
+            <label for="{{ field.id_for_label }}">{{ field.label }}{% if field.field.required %} <span aria-hidden="true">*</span>{% endif %}</label>
+            {{ field }}
+            {% if field.help_text %}<p class="help-text">{{ field.help_text }}</p>{% endif %}
+            {{ field.errors }}
+        </div>
+    {% endfor %}
+
+    <div class="import-note">
+        <strong>What gets filled automatically?</strong>
+        <p>Only the title and question text. Difficulty, pattern, topic, answers and notes stay blank.</p>
+    </div>
+
+    <div class="button-row form-actions">
+        <button class="button" type="submit">Extract questions</button>
+        <a class="button button-secondary" href="{% url 'questions:list' %}">Cancel</a>
+    </div>
+</form>
+{% endblock %}
