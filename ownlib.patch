diff --git a/apps/questions/management/commands/convert_saved_built_ins.py b/apps/questions/management/commands/convert_saved_built_ins.py
new file mode 100644
index 0000000..e698df0
--- /dev/null
+++ b/apps/questions/management/commands/convert_saved_built_ins.py
@@ -0,0 +1,35 @@
+from django.core.management.base import BaseCommand
+
+from apps.questions.models import UserQuestionState
+from apps.questions.services import copy_built_in_question_for_user
+
+
+class Command(BaseCommand):
+    help = "Convert legacy bookmarked built-in questions into owned user copies."
+
+    def handle(self, *args, **options):
+        saved_states = list(
+            UserQuestionState.objects.select_related("user", "question").filter(
+                bookmarked=True,
+                question__is_system=True,
+            )
+        )
+
+        converted_count = 0
+        existing_count = 0
+        for state in saved_states:
+            _, created = copy_built_in_question_for_user(
+                question=state.question,
+                user=state.user,
+            )
+            if created:
+                converted_count += 1
+            else:
+                existing_count += 1
+
+        self.stdout.write(
+            self.style.SUCCESS(
+                f"Converted {converted_count} saved built-in questions; "
+                f"{existing_count} already had copies."
+            )
+        )
