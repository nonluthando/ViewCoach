diff --git a/templates/roadmaps/roadmap_detail.html b/templates/roadmaps/roadmap_detail.html
new file mode 100644
index 0000000..158d2f3
--- /dev/null
+++ b/templates/roadmaps/roadmap_detail.html
@@ -0,0 +1,86 @@
+{% extends "base.html" %}
+
+{% block title %}{{ roadmap.title }} Roadmap | ViewCoach{% endblock %}
+
+{% block content %}
+<nav class="roadmap-breadcrumbs" aria-label="Breadcrumb">
+    <a href="{% url 'roadmaps:list' %}">Roadmaps</a>
+    <span aria-hidden="true">/</span>
+    <span>{{ roadmap.title }}</span>
+</nav>
+
+<section class="roadmap-detail-header">
+    <div class="roadmap-detail-copy">
+        <p class="eyebrow">{{ roadmap.get_kind_display }}</p>
+        <h1>{{ roadmap.title }}</h1>
+        <p class="lead">{{ roadmap.description }}</p>
+    </div>
+    <div class="roadmap-detail-progress">
+        <span class="roadmap-detail-percentage">{{ progress.percentage }}%</span>
+        <span>{{ progress.completed_count }} of {{ progress.total_count }} topics complete</span>
+        <div class="roadmap-progress-track" role="progressbar" aria-label="Roadmap progress" aria-valuemin="0" aria-valuemax="100" aria-valuenow="{{ progress.percentage }}">
+            <span style="width: {{ progress.percentage }}%"></span>
+        </div>
+        {% if user_roadmap %}
+            <strong>{{ user_roadmap.get_status_display }}</strong>
+        {% else %}
+            <form method="post" action="{% url 'roadmaps:start' roadmap.slug %}">
+                {% csrf_token %}
+                <button class="button" type="submit">Start this roadmap</button>
+            </form>
+        {% endif %}
+    </div>
+</section>
+
+<div class="roadmap-summary-strip">
+    <span><strong>{{ sections|length }}</strong> sections</span>
+    <span><strong>{{ progress.total_count }}</strong> topics</span>
+    <span><strong>{{ progress.in_progress_count }}</strong> currently learning</span>
+</div>
+
+<section class="roadmap-outline" aria-label="{{ roadmap.title }} curriculum">
+    {% for section in sections %}
+        <details class="roadmap-section" {% if forloop.first %}open{% endif %}>
+            <summary>
+                <span class="roadmap-section-number">{{ forloop.counter|stringformat:"02d" }}</span>
+                <span class="roadmap-section-heading">
+                    <strong>{{ section.title }}</strong>
+                    <span>{{ section.topic_items|length }} topic{{ section.topic_items|length|pluralize }}</span>
+                </span>
+                <span class="roadmap-section-toggle" aria-hidden="true">+</span>
+            </summary>
+            {% if section.description %}<p class="roadmap-section-description">{{ section.description }}</p>{% endif %}
+            <ol class="roadmap-topic-list">
+                {% for topic in section.topic_items %}
+                    <li id="topic-{{ topic.pk }}" class="roadmap-topic roadmap-topic-{{ topic.current_status|lower }}">
+                        <div class="roadmap-topic-copy">
+                            <span class="roadmap-topic-marker" aria-hidden="true">
+                                {% if topic.current_status == "COMPLETED" %}✓{% elif topic.current_status == "IN_PROGRESS" %}→{% else %}○{% endif %}
+                            </span>
+                            <div>
+                                <strong>{{ topic.title }}</strong>
+                                {% if topic.description %}<p>{{ topic.description }}</p>{% endif %}
+                            </div>
+                        </div>
+                        <form class="roadmap-topic-actions" method="post" action="{% url 'roadmaps:update_topic_status' roadmap.slug topic.pk %}">
+                            {% csrf_token %}
+                            <span class="roadmap-status-label">{{ topic.current_progress.get_status_display|default:"Not started" }}</span>
+                            <div class="roadmap-status-buttons" role="group" aria-label="Set status for {{ topic.title }}">
+                                <button class="status-button {% if topic.current_status == 'NOT_STARTED' %}is-current{% endif %}"
+                                        type="submit" name="status" value="NOT_STARTED"
+                                        aria-label="Mark {{ topic.title }} not started" aria-pressed="{% if topic.current_status == 'NOT_STARTED' %}true{% else %}false{% endif %}">○</button>
+                                <button class="status-button {% if topic.current_status == 'IN_PROGRESS' %}is-current{% endif %}"
+                                        type="submit" name="status" value="IN_PROGRESS"
+                                        aria-label="Mark {{ topic.title }} in progress" aria-pressed="{% if topic.current_status == 'IN_PROGRESS' %}true{% else %}false{% endif %}">→</button>
+                                <button class="status-button status-complete {% if topic.current_status == 'COMPLETED' %}is-current{% endif %}"
+                                        type="submit" name="status" value="COMPLETED"
+                                        aria-label="Mark {{ topic.title }} completed" aria-pressed="{% if topic.current_status == 'COMPLETED' %}true{% else %}false{% endif %}">✓</button>
+                            </div>
+                        </form>
+                    </li>
+                {% endfor %}
+            </ol>
+        </details>
+    {% endfor %}
+</section>
+{% endblock %}
diff --git a/templates/roadmaps/roadmap_list.html b/templates/roadmaps/roadmap_list.html
new file mode 100644
index 0000000..fcf3fc9
--- /dev/null
+++ b/templates/roadmaps/roadmap_list.html
@@ -0,0 +1,60 @@
+{% extends "base.html" %}
+
+{% block title %}Roadmaps | ViewCoach{% endblock %}
+
+{% block content %}
+<section class="page-header roadmap-page-header">
+    <p class="eyebrow">Learning roadmaps</p>
+    <h1>Choose what you are building towards.</h1>
+    <p class="lead">Follow a structured path, learn each topic however you prefer, and keep your progress in one place.</p>
+</section>
+
+{% for group in roadmap_groups %}
+    <section class="roadmap-group">
+        <div class="roadmap-group-heading">
+            <div>
+                <p class="eyebrow">{{ group.label }}</p>
+                <h2>
+                    {% if group.kind == "ROLE" %}Prepare for a role
+                    {% elif group.kind == "SKILL" %}Build a focused skill
+                    {% else %}Turn knowledge into practice
+                    {% endif %}
+                </h2>
+            </div>
+            <span>{{ group.items|length }} roadmap{{ group.items|length|pluralize }}</span>
+        </div>
+
+        <div class="roadmap-catalogue">
+            {% for item in group.items %}
+                <article class="roadmap-card">
+                    <div class="roadmap-card-main">
+                        <div class="roadmap-card-meta">
+                            <span>{{ item.topic_count }} topics</span>
+                            {% if item.enrolment %}<span>{{ item.enrolment.get_status_display }}</span>{% else %}<span>Not started</span>{% endif %}
+                        </div>
+                        <h3><a href="{% url 'roadmaps:detail' item.roadmap.slug %}">{{ item.roadmap.title }}</a></h3>
+                        <p>{{ item.roadmap.description }}</p>
+                    </div>
+                    <div class="roadmap-card-progress">
+                        <div class="roadmap-progress-copy">
+                            <strong>{{ item.percentage }}%</strong>
+                            <span>{{ item.completed_count }} of {{ item.topic_count }} complete</span>
+                        </div>
+                        <div class="roadmap-progress-track" role="progressbar" aria-label="Roadmap progress" aria-valuemin="0" aria-valuemax="100" aria-valuenow="{{ item.percentage }}">
+                            <span style="width: {{ item.percentage }}%"></span>
+                        </div>
+                        <a class="roadmap-card-link" href="{% url 'roadmaps:detail' item.roadmap.slug %}">
+                            {% if item.enrolment %}Continue roadmap{% else %}View roadmap{% endif %}
+                        </a>
+                    </div>
+                </article>
+            {% endfor %}
+        </div>
+    </section>
+{% empty %}
+    <div class="empty-state empty-state-wide">
+        <h2>No roadmaps are published yet</h2>
+        <p>Run the roadmap seed command to create the built-in catalogue.</p>
+    </div>
+{% endfor %}
+{% endblock %}
