diff --git a/apps/questions/services.py b/apps/questions/services.py
new file mode 100644
index 0000000..2b8062e
--- /dev/null
+++ b/apps/questions/services.py
@@ -0,0 +1,191 @@
+from copy import deepcopy
+
+from django.db import IntegrityError, transaction
+
+from .models import (
+    BehaviouralQuestion,
+    ConceptQuestion,
+    DebugQuestion,
+    Question,
+    TechnicalQuestion,
+    UserQuestionNote,
+    UserQuestionState,
+)
+
+
+COMMON_COPY_FIELDS = (
+    "title",
+    "prompt",
+    "company",
+    "difficulty",
+)
+
+TECHNICAL_COPY_FIELDS = (
+    "topic",
+    "first_hint",
+    "pattern",
+    "data_structure",
+    "intuition",
+    "brute_force",
+    "brute_force_time_complexity",
+    "brute_force_space_complexity",
+    "optimal_approach",
+    "optimal_time_complexity",
+    "optimal_space_complexity",
+    "complexity",
+    "mistakes",
+    "progressive_hints",
+    "code",
+)
+
+CONCEPT_COPY_FIELDS = (
+    "category",
+    "canonical_answer",
+    "key_points",
+    "example",
+    "common_misconception",
+    "code_snippet",
+)
+
+BEHAVIOURAL_COPY_FIELDS = (
+    "star_answer",
+    "leadership_principles",
+    "stories",
+    "follow_ups",
+    "competencies",
+    "star_outline",
+    "personal_detail_prompts",
+    "follow_up_questions",
+    "common_mistakes",
+)
+
+DEBUG_COPY_FIELDS = (
+    "repository",
+    "bug_type",
+    "failing_test_or_symptom",
+    "broken_code",
+    "likely_bug",
+    "reasoning",
+    "fix",
+    "tests",
+    "common_mistake",
+)
+
+MODEL_AND_FIELDS_BY_TYPE = {
+    Question.Type.TECHNICAL: (TechnicalQuestion, TECHNICAL_COPY_FIELDS),
+    Question.Type.CONCEPT: (ConceptQuestion, CONCEPT_COPY_FIELDS),
+    Question.Type.BEHAVIOURAL: (BehaviouralQuestion, BEHAVIOURAL_COPY_FIELDS),
+    Question.Type.DEBUG: (DebugQuestion, DEBUG_COPY_FIELDS),
+}
+
+
+def _copy_values(source, field_names):
+    return {
+        field_name: deepcopy(getattr(source, field_name))
+        for field_name in field_names
+    }
+
+
+def _initial_status(source):
+    if source.question_type == Question.Type.TECHNICAL:
+        has_notes = any(
+            value.strip()
+            for value in (
+                source.intuition,
+                source.brute_force,
+                source.optimal_approach,
+            )
+        )
+    elif source.question_type == Question.Type.CONCEPT:
+        has_notes = bool(source.canonical_answer.strip())
+    elif source.question_type == Question.Type.BEHAVIOURAL:
+        has_notes = bool(source.star_answer.strip())
+    else:
+        has_notes = bool(source.fix.strip())
+
+    if has_notes:
+        return Question.Status.READY_FOR_REVIEW
+    return Question.Status.NEEDS_NOTES
+
+
+def _move_existing_personal_notes(*, user, source_question, copied_question):
+    source_note = UserQuestionNote.objects.filter(
+        user=user,
+        question=source_question,
+    ).first()
+    if source_note is None:
+        return
+
+    UserQuestionNote.objects.update_or_create(
+        user=user,
+        question=copied_question,
+        defaults={
+            "notes": source_note.notes,
+            "mistakes": source_note.mistakes,
+            "code_notes": source_note.code_notes,
+            "behavioural_notes": source_note.behavioural_notes,
+        },
+    )
+    source_note.delete()
+
+
+def _consolidate_legacy_user_data(*, user, source_question, copied_question):
+    _move_existing_personal_notes(
+        user=user,
+        source_question=source_question,
+        copied_question=copied_question,
+    )
+    UserQuestionState.objects.filter(
+        user=user,
+        question=source_question,
+    ).delete()
+
+
+def copy_built_in_question_for_user(*, question, user):
+    if not question.is_system:
+        raise ValueError("Only built-in questions can be added to a user library.")
+
+    existing_copy = Question.objects.filter(
+        owner=user,
+        source_system_question=question,
+    ).first()
+    if existing_copy is not None:
+        copied_question = existing_copy.specific
+        _consolidate_legacy_user_data(
+            user=user,
+            source_question=question,
+            copied_question=copied_question,
+        )
+        return copied_question, False
+
+    source = question.specific
+    model_class, type_fields = MODEL_AND_FIELDS_BY_TYPE[question.question_type]
+    copied_values = _copy_values(source, COMMON_COPY_FIELDS + type_fields)
+
+    try:
+        with transaction.atomic():
+            copied_question = model_class.objects.create(
+                owner=user,
+                source_system_question=question,
+                is_system=False,
+                status=_initial_status(source),
+                **copied_values,
+            )
+            _consolidate_legacy_user_data(
+                user=user,
+                source_question=question,
+                copied_question=copied_question,
+            )
+    except IntegrityError:
+        copied_question = Question.objects.get(
+            owner=user,
+            source_system_question=question,
+        ).specific
+        _consolidate_legacy_user_data(
+            user=user,
+            source_question=question,
+            copied_question=copied_question,
+        )
+        return copied_question, False
+
+    return copied_question, True
