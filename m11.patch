+.import-item-grid {
+    display: grid;
+    grid-template-columns: minmax(0, 2fr) minmax(10rem, 1fr);
+    gap: 1rem;
+}
+
+.duplicate-warning {
+    padding: 0.65rem 0.8rem;
+    color: #8b2935;
+    background: #ffecef;
+    border-radius: 0.55rem;
+    font-weight: 700;
+}
+
+.import-confirm-panel {
+    margin-top: 2rem;
+    background: #f7f8ff;
+}
+.import-confirm-panel h2 { margin: 0 0 0.35rem; }
+.import-confirm-panel p { margin: 0; color: #526078; }
+
+.import-history-card h2 { margin: 0.65rem 0 0.25rem; font-size: 1.2rem; }
+.import-history-card p { margin: 0; color: #606a7e; }
+
+.button-danger { background: #a21d2e; }
+.button[disabled] { cursor: wait; opacity: 0.68; }
+
+@media (max-width: 48rem) {
+    .bulk-toolbar,
+    .import-confirm-panel,
+    .import-history-card,
+    .import-item-heading {
+        align-items: stretch;
+        flex-direction: column;
+    }
+
+    .import-item-grid { grid-template-columns: 1fr; }
+}
