+{% extends "base.html" %}
+
+{% block title %}Question Library | Adaptive Interview Coach{% endblock %}
+
+{% block content %}
+<section class="page-header page-header-split">
+    <div>
+        <p class="eyebrow">Question library</p>
+        <h1>Your interview material</h1>
+        <p class="lead">Build structured questions you can practise, reveal progressively and review later.</p>
+    </div>
+    <a class="button" href="{% url 'questions:choose_type' %}">Add question</a>
+</section>
+
+<form class="filter-panel" method="get" role="search">
+    <div class="filter-grid">
+        <div class="form-field filter-search">
+            <label for="question-search">Search</label>
+            <input id="question-search" type="search" name="q" value="{{ filters.q }}" placeholder="Title, prompt, topic, company…">
+        </div>
+        <div class="form-field">
+            <label for="question-type">Type</label>
+            <select id="question-type" name="type">
+                <option value="">All types</option>
+                {% for value, label in question_types %}
+                    <option value="{{ value }}" {% if filters.type == value %}selected{% endif %}>{{ label }}</option>
+                {% endfor %}
+            </select>
+        </div>
+        <div class="form-field">
+            <label for="question-difficulty">Difficulty</label>
+            <select id="question-difficulty" name="difficulty">
+                <option value="">All levels</option>
+                {% for value, label in difficulties %}
+                    <option value="{{ value }}" {% if filters.difficulty == value %}selected{% endif %}>{{ label }}</option>
+                {% endfor %}
+            </select>
+        </div>
+        <div class="form-field">
+            <label for="question-status">Status</label>
+            <select id="question-status" name="status">
+                <option value="">All statuses</option>
+                {% for value, label in statuses %}
+                    <option value="{{ value }}" {% if filters.status == value %}selected{% endif %}>{{ label }}</option>
+                {% endfor %}
+            </select>
+        </div>
+    </div>
+    <div class="button-row">
+        <button class="button button-small" type="submit">Apply filters</button>
+        <a class="button button-small button-secondary" href="{% url 'questions:list' %}">Clear</a>
+    </div>
+</form>
+
+{% if page.object_list %}
+    <div class="question-grid">
+        {% for question in page.object_list %}
+            <article class="question-card">
+                <div class="question-card-meta">
+                    <span class="badge badge-{{ question.question_type|lower }}">{{ question.get_question_type_display }}</span>
+                    <span class="badge badge-neutral">{{ question.get_status_display }}</span>
+                    {% if question.difficulty %}<span class="badge badge-neutral">{{ question.get_difficulty_display }}</span>{% endif %}
+                </div>
+                <h2><a href="{% url 'questions:detail' question.pk %}">{{ question.title }}</a></h2>
+                <p>{{ question.prompt|truncatewords:24 }}</p>
+                <div class="question-card-footer">
+                    <span>{% if question.company %}{{ question.company }}{% else %}General preparation{% endif %}</span>
+                    <span>Updated {{ question.updated_at|date:"j M" }}</span>
+                </div>
+            </article>
+        {% endfor %}
+    </div>
+
+    {% if page.paginator.num_pages > 1 %}
+        <nav class="pagination" aria-label="Question library pages">
+            {% if page.has_previous %}
+                <a href="?page={{ page.previous_page_number }}&q={{ filters.q|urlencode }}&type={{ filters.type }}&difficulty={{ filters.difficulty }}&status={{ filters.status }}">Previous</a>
+            {% endif %}
+            <span>Page {{ page.number }} of {{ page.paginator.num_pages }}</span>
+            {% if page.has_next %}
+                <a href="?page={{ page.next_page_number }}&q={{ filters.q|urlencode }}&type={{ filters.type }}&difficulty={{ filters.difficulty }}&status={{ filters.status }}">Next</a>
+            {% endif %}
+        </nav>
+    {% endif %}
+{% else %}
+    <div class="empty-state empty-state-wide">
+        <h2>{% if filters.q or filters.type or filters.difficulty or filters.status %}No matching questions{% else %}Your library is empty{% endif %}</h2>
+        <p>{% if filters.q or filters.type or filters.difficulty or filters.status %}Try clearing a filter or searching for something else.{% else %}Start with one question you genuinely need to explain in an interview.{% endif %}</p>
+        {% if filters.q or filters.type or filters.difficulty or filters.status %}
+            <a class="button button-secondary" href="{% url 'questions:list' %}">Clear filters</a>
+        {% else %}
+            <a class="button" href="{% url 'questions:choose_type' %}">Add your first question</a>
+        {% endif %}
+    </div>
+{% endif %}
+{% endblock %}
diff --git a/templates/questions/technical_question_detail.html b/templates/questions/technical_question_detail.html
new file mode 100644
index 0000000..d9d0c0b
--- /dev/null
+++ b/templates/questions/technical_question_detail.html
@@ -0,0 +1,118 @@
+{% extends "base.html" %}
+
+{% block title %}{{ question.title }} | Adaptive Interview Coach{% endblock %}
+
+{% block content %}
+{% include "questions/_question_header.html" %}
+
+<section class="practice-card">
+    <p class="eyebrow">Problem</p>
+    <div class="rich-text">{{ question.prompt|linebreaks }}</div>
+</section>
+
+<section class="reveal-workspace" data-progressive-reveal>
+    <div class="reveal-toolbar">
+        <div>
+            <p class="eyebrow">Progressive reveal</p>
+            <h2>Try first. Reveal only what you need.</h2>
+        </div>
+        <button class="button" type="button" data-reveal-next>Reveal next step</button>
+    </div>
+
+    <div class="reveal-empty" data-reveal-empty>
+        <p>Your saved reasoning is hidden. Explain the problem aloud or sketch your approach before revealing a hint.</p>
+    </div>
+
+    <div class="reveal-steps">
+        {% if specific.first_hint %}
+            <article class="reveal-step" data-reveal-step hidden>
+                <p class="step-number">Step 1</p><h3>First hint</h3>
+                <div class="rich-text">{{ specific.first_hint|linebreaks }}</div>
+            </article>
+        {% endif %}
+        {% if specific.pattern %}
+            <article class="reveal-step" data-reveal-step hidden>
+                <p class="step-number">Next clue</p><h3>Pattern</h3><p>{{ specific.pattern }}</p>
+            </article>
+        {% endif %}
+        {% if specific.data_structure %}
+            <article class="reveal-step" data-reveal-step hidden>
+                <p class="step-number">Next clue</p><h3>Data structure</h3><p>{{ specific.data_structure }}</p>
+            </article>
+        {% endif %}
+        {% if specific.brute_force %}
+            <article class="reveal-step" data-reveal-step hidden>
+                <p class="step-number">Approach</p><h3>Brute force</h3>
+                <div class="rich-text">{{ specific.brute_force|linebreaks }}</div>
+            </article>
+        {% endif %}
+        {% if specific.intuition or specific.optimal_approach %}
+            <article class="reveal-step" data-reveal-step hidden>
+                <p class="step-number">Solution</p><h3>Optimal approach</h3>
+                {% if specific.intuition %}<h4>Intuition</h4><div class="rich-text">{{ specific.intuition|linebreaks }}</div>{% endif %}
+                {% if specific.optimal_approach %}<h4>Steps</h4><div class="rich-text">{{ specific.optimal_approach|linebreaks }}</div>{% endif %}
+            </article>
+        {% endif %}
+        {% if specific.complexity %}
+            <article class="reveal-step" data-reveal-step hidden>
+                <p class="step-number">Analysis</p><h3>Complexity</h3><p>{{ specific.complexity }}</p>
+            </article>
+        {% endif %}
+        {% if specific.code %}
+            <article class="reveal-step" data-reveal-step hidden>
+                <p class="step-number">Implementation</p><h3>Code</h3><pre><code>{{ specific.code }}</code></pre>
+            </article>
+        {% endif %}
+        {% if specific.mistakes %}
+            <article class="reveal-step" data-reveal-step hidden>
+                <p class="step-number">Reflection</p><h3>Mistakes to avoid</h3>
+                <div class="rich-text">{{ specific.mistakes|linebreaks }}</div>
+            </article>
+        {% endif %}
+    </div>
+
+    <button class="link-button reset-reveal" type="button" data-reveal-reset hidden>Hide everything and try again</button>
+</section>
+
+{% if specific.topic %}<p class="metadata-line"><strong>Topic:</strong> {{ specific.topic }}</p>{% endif %}
+<p class="back-link"><a href="{% url 'questions:list' %}">← Back to question library</a></p>
+
+<script>
+(function () {
+    const workspace = document.querySelector("[data-progressive-reveal]");
+    if (!workspace) return;
+
+    const steps = Array.from(workspace.querySelectorAll("[data-reveal-step]"));
+    const nextButton = workspace.querySelector("[data-reveal-next]");
+    const resetButton = workspace.querySelector("[data-reveal-reset]");
+    const emptyState = workspace.querySelector("[data-reveal-empty]");
+    let visibleCount = 0;
+
+    function updateControls() {
+        emptyState.hidden = visibleCount > 0;
+        resetButton.hidden = visibleCount === 0;
+        nextButton.hidden = visibleCount >= steps.length;
+        if (visibleCount < steps.length) {
+            nextButton.textContent = visibleCount === 0 ? "Reveal first hint" : "Reveal next step";
+        }
+    }
+
+    nextButton.addEventListener("click", function () {
+        if (visibleCount >= steps.length) return;
+        steps[visibleCount].hidden = false;
+        steps[visibleCount].scrollIntoView({ behavior: "smooth", block: "nearest" });
+        visibleCount += 1;
+        updateControls();
+    });
+
+    resetButton.addEventListener("click", function () {
+        steps.forEach(function (step) { step.hidden = true; });
+        visibleCount = 0;
+        updateControls();
+        workspace.scrollIntoView({ behavior: "smooth", block: "start" });
+    });
+
+    updateControls();
+})();
+</script>
+{% endblock %}
