diff --git a/templates/planner/today.html b/templates/planner/today.html
new file mode 100644
index 0000000000000000000000000000000000000000..124ab3d754cfc9daf3062679ef11c321fbc5f43b
--- /dev/null
+++ b/templates/planner/today.html
@@ -0,0 +1,113 @@
+{% extends "base.html" %}
+
+{% block title %}Today’s Plan | ViewCoach{% endblock %}
+{% block body_class %}planner-page{% endblock %}
+
+{% block content %}
+<section class="planner-header">
+    <div>
+        <p class="eyebrow">Adaptive study planner</p>
+        <h1>Today’s plan</h1>
+        <p>A focused session assembled from what is due, what is in progress and what needs attention.</p>
+    </div>
+    <div class="planner-header-actions">
+        {% if active_session %}
+            <form method="post" action="{% url 'planner:finish_session' %}">
+                {% csrf_token %}
+                <button class="button button-secondary" type="submit">End session</button>
+            </form>
+        {% else %}
+            <form method="post" action="{% url 'planner:start_session' %}">
+                {% csrf_token %}
+                <button class="button" type="submit">Start study session</button>
+            </form>
+        {% endif %}
+    </div>
+</section>
+
+<div class="planner-layout">
+    <main class="planner-main">
+        <section class="planner-summary" aria-labelledby="planner-summary-heading">
+            <div>
+                <p class="planner-summary-number">{{ estimated_minutes }} <span>minutes</span></p>
+                <h2 id="planner-summary-heading">
+                    {% if is_complete %}Plan complete{% else %}{{ total_count }} focused task{{ total_count|pluralize }}{% endif %}
+                </h2>
+                <p>{{ completed_count }} of {{ total_count }} completed</p>
+            </div>
+            <div class="planner-progress" aria-label="{{ completed_count }} of {{ total_count }} tasks complete">
+                <span style="--planner-progress: {% widthratio completed_count total_count 100 %}%"></span>
+            </div>
+            {% if active_session %}
+                <p class="planner-session-note">
+                    Session started at <time datetime="{{ active_session.started_at|date:'c' }}">{{ active_session.started_at|date:"H:i" }}</time>.
+                </p>
+            {% endif %}
+        </section>
+
+        <ol class="planner-recommendations">
+            {% for recommendation in recommendations %}
+                <li class="planner-recommendation{% if recommendation.is_completed %} is-complete{% endif %}">
+                    <div class="planner-recommendation-marker" aria-hidden="true">{{ forloop.counter }}</div>
+                    <article>
+                        <div class="planner-recommendation-meta">
+                            <span class="planner-kind planner-kind-{{ recommendation.kind|lower }}">{{ recommendation.get_kind_display }}</span>
+                            <span>{{ recommendation.estimated_minutes }} min</span>
+                        </div>
+                        <h2>{{ recommendation.title }}</h2>
+                        <p>{{ recommendation.description }}</p>
+                        {% if recommendation.rationale %}
+                            <p class="planner-rationale"><strong>Why this:</strong> {{ recommendation.rationale }}</p>
+                        {% endif %}
+                        <div class="planner-recommendation-actions">
+                            <a class="button button-small{% if recommendation.is_completed %} button-secondary{% endif %}" href="{{ recommendation.action_url }}">
+                                {{ recommendation.action_label }}
