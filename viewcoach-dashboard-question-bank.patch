diff --git a/static/css/editorial.css b/static/css/editorial.css
--- a/static/css/editorial.css
+++ b/static/css/editorial.css
@@ -768,5 +768,556 @@
 .mobile-nav-link svg {
     width: 1.15rem;
     height: 1.15rem;
     margin-bottom: 0.18rem;
 }
+
+/* Milestone 2.1B: editorial dashboard and question bank */
+.visually-hidden {
+    position: absolute;
+    width: 1px;
+    height: 1px;
+    padding: 0;
+    margin: -1px;
+    overflow: hidden;
+    clip: rect(0, 0, 0, 0);
+    white-space: nowrap;
+    border: 0;
+}
+
+.dashboard-editorial-header,
+.bank-page-header {
+    display: flex;
+    align-items: flex-end;
+    justify-content: space-between;
+    gap: 2rem;
+    width: min(100%, 80rem);
+    padding-bottom: 1.75rem;
+    margin: 0 auto 2rem;
+    border-bottom: 1px solid var(--vc-border);
+}
+
+.dashboard-editorial-header h1,
+.bank-page-header h1 {
+    margin: 0.3rem 0 0.6rem;
+    font-size: clamp(2.65rem, 6vw, 4.7rem);
+    line-height: 0.98;
+    letter-spacing: -0.045em;
+}
+
+.dashboard-editorial-header p:last-child,
+.bank-page-header p:last-child {
+    max-width: 43rem;
+    margin: 0;
+    color: var(--vc-muted);
+}
+
+.dashboard-editorial-layout {
+    display: grid;
+    width: min(100%, 80rem);
+    grid-template-columns: minmax(0, 1fr) 20rem;
+    gap: clamp(1.5rem, 3vw, 3rem);
+    align-items: start;
+    margin-inline: auto;
+}
+
+.dashboard-primary-column {
+    display: grid;
+    gap: 2.5rem;
+    min-width: 0;
+}
+
+.dashboard-priority {
+    padding: clamp(1.5rem, 3vw, 2.5rem);
+    border: 1px solid var(--vc-border);
+    border-top: 4px solid var(--vc-burgundy);
+    background: var(--vc-paper);
+}
+
+.dashboard-section-label {
+    display: flex;
+    align-items: center;
+    gap: 0.55rem;
+    color: var(--vc-muted);
+    font-size: 0.75rem;
+    font-weight: 800;
+    letter-spacing: 0.1em;
+    text-transform: uppercase;
+}
+
+.dashboard-status-dot {
+    width: 0.55rem;
+    height: 0.55rem;
+    border-radius: 50%;
+    background: var(--vc-burgundy);
+}
+
+.dashboard-status-dot.is-clear { background: var(--vc-success); }
+
+.dashboard-priority-number {
+    margin: 1.75rem 0 0.4rem;
+    font-family: var(--vc-font-serif);
+    font-size: clamp(3rem, 8vw, 5.5rem);
+    line-height: 0.9;
+    letter-spacing: -0.055em;
+}
+
+.dashboard-priority-number span {
+    color: var(--vc-muted);
+    font-family: var(--vc-font-sans);
+    font-size: 0.88rem;
+    font-weight: 750;
+    letter-spacing: 0;
+}
+
+.dashboard-priority h2 {
+    max-width: 48rem;
+    margin: 1.3rem 0 0.65rem;
+    font-size: clamp(1.65rem, 3vw, 2.4rem);
+    line-height: 1.12;
+}
+
+.dashboard-priority-copy {
+    max-width: 48rem;
+    margin: 0;
+    color: var(--vc-muted);
+    line-height: 1.7;
+}
+
+.dashboard-priority-actions {
+    display: flex;
+    flex-wrap: wrap;
+    align-items: center;
+    gap: 1rem;
+    margin-top: 1.75rem;
+}
+
+.dashboard-text-link,
+.dashboard-section-heading > a {
+    color: var(--vc-burgundy-dark);
+    font-size: 0.84rem;
+    font-weight: 750;
+    text-decoration: none;
+}
+
+.dashboard-text-link:hover,
+.dashboard-section-heading > a:hover { text-decoration: underline; }
+
+.dashboard-recent { border-top: 2px solid var(--vc-ink); }
+
+.dashboard-section-heading {
+    display: flex;
+    align-items: end;
+    justify-content: space-between;
+    gap: 1.5rem;
+    padding: 1.25rem 0 1rem;
+}
+
+.dashboard-section-heading h2 {
