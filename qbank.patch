+      "java_solution": "import java.util.ArrayDeque;\nimport java.util.ArrayList;\nimport java.util.List;\nimport java.util.Queue;\n\npublic class Main {\n    public static int shortestDistance(\n            int nodeCount,\n            int[][] edges,\n            int startNode,\n            int targetNode) {\n\n        List<List<Integer>> neighbours = new ArrayList<>();\n\n        for (int node = 0; node < nodeCount; node++) {\n            neighbours.add(new ArrayList<>());\n        }\n\n        for (int[] edge : edges) {\n            int firstNode = edge[0];\n            int secondNode = edge[1];\n            neighbours.get(firstNode).add(secondNode);\n            neighbours.get(secondNode).add(firstNode);\n        }\n\n        Queue<int[]> queue = new ArrayDeque<>();\n        boolean[] visited = new boolean[nodeCount];\n\n        queue.offer(new int[] {startNode, 0});\n        visited[startNode] = true;\n\n        while (!queue.isEmpty()) {\n            int[] currentEntry = queue.poll();\n            int currentNode = currentEntry[0];\n            int currentDistance = currentEntry[1];\n\n            if (currentNode == targetNode) {\n                return currentDistance;\n            }\n\n            for (int neighbour : neighbours.get(currentNode)) {\n                if (!visited[neighbour]) {\n                    visited[neighbour] = true;\n                    int neighbourDistance = currentDistance + 1;\n                    queue.offer(new int[] {neighbour, neighbourDistance});\n                }\n            }\n        }\n\n        return -1;\n    }\n\n    public static void main(String[] args) {\n        int[][] edges = {\n                {0, 1},\n                {1, 2},\n                {0, 3},\n                {3, 4},\n                {4, 2}\n        };\n\n        System.out.println(shortestDistance(5, edges, 0, 2));\n    }\n}"
