+      "java_solution": "import java.util.Arrays;\nimport java.util.HashMap;\nimport java.util.Map;\nimport java.util.PriorityQueue;\n\npublic class Main {\n    public static int[] topKFrequent(int[] numbers, int k) {\n        Map<Integer, Integer> frequencyByValue = new HashMap<>();\n\n        for (int value : numbers) {\n            int currentFrequency = frequencyByValue.getOrDefault(value, 0);\n            frequencyByValue.put(value, currentFrequency + 1);\n        }\n\n        PriorityQueue<int[]> leastFrequentFirst =\n                new PriorityQueue<>((first, second) -> {\n                    int frequencyComparison = Integer.compare(first[1], second[1]);\n\n                    if (frequencyComparison != 0) {\n                        return frequencyComparison;\n                    }\n\n                    return Integer.compare(first[0], second[0]);\n                });\n\n        for (Map.Entry<Integer, Integer> entry : frequencyByValue.entrySet()) {\n            int value = entry.getKey();\n            int frequency = entry.getValue();\n            leastFrequentFirst.offer(new int[] {value, frequency});\n\n            if (leastFrequentFirst.size() > k) {\n                leastFrequentFirst.poll();\n            }\n        }\n\n        int[] result = new int[k];\n\n        for (int index = k - 1; index >= 0; index--) {\n            int[] valueAndFrequency = leastFrequentFirst.poll();\n            result[index] = valueAndFrequency[0];\n        }\n\n        return result;\n    }\n\n    public static void main(String[] args) {\n        int[] numbers = {4, 4, 4, 2, 2, 9, 9, 9, 9, 7};\n        System.out.println(Arrays.toString(topKFrequent(numbers, 2)));\n    }\n}"
